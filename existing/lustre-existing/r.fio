[global]
;name=fio-rand-write
directory=/mnt/client
;directory=/mnt/gluster
;directory=/mnt/beegfs
;filename=/dev/nvme0n1
;rw=write
rw=randwrite
bs=1024k
;bs=4k
direct=0
;direct=1
numjobs=128
;verify=meta
;time_based
;runtime=60
;runtime=40
;runtime=30
group_reporting

[amd2]
;size=3G
size=100M
;nrfiles=2
;ioengine=libaio
;ioengine=pvsync2
;hipri
;iodepth=16
