[global]
;name=fio-rand-read
directory=/mnt/client
;directory=/mnt/gluster
;directory=/mnt/beegfs
;filename=/dev/nvme0n1
rw=randread
;bs=1m
bs=4k
direct=1
numjobs=128
;verify=meta
;time_based
;runtime=60
;runtime=40
;runtime=30
group_reporting

[amd2]
;size=3G
size=200M
;nrfiles=2
;ioengine=libaio
;ioengine=pvsync2
;hipri
;iodepth=16
