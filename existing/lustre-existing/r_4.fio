[global]
;name=fio-rand-write
directory=/mnt/client
;directory=/mnt/gluster
;directory=/mnt/beegfs
;filename=/dev/nvme0n1
;rw=randrw
;rw=write
rw=randwrite
;rw=randread
bs=4k
;bs=1m
direct=0
;direct=1
;numjobs=128
numjobs=32
;numjobs=1
;verify=meta
time_based
;runtime=60
;runtime=40
runtime=30
group_reporting

[amd2]
;size=3G
size=5G
;nrfiles=2
;ioengine=libaio
;ioengine=pvsync2
;hipri
;iodepth=16
;end_fsync=1
fsync_on_close=1
fsync=1
